# ============================================================
# ShorTree — Environment Variables
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local` to version control.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Your project's public URL
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co

# Public anon key — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# ── Database (Prisma) ─────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → Database → Connection string
# Use the "URI" format. Append `?pgbouncer=true&connection_limit=1`
# when deploying to serverless (Vercel, etc.) to use the pooler.

DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<dbname>?schema=public

# ── Next.js ───────────────────────────────────────────────────
# The canonical URL of your deployment (used for redirects, OG tags, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000
