{
  "name": "shorted",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:migrate": "npx dotenv-cli -e .env -- prisma migrate deploy",
    "db:push": "npx dotenv-cli -e .env -- prisma db push",
    "backfill:tree-codes": "npx dotenv-cli -e .env -- node scripts/backfill-tree-short-codes.cjs",
    "backfill:hebrew-dates": "npx dotenv-cli -e .env -- tsx --conditions=import scripts/backfill-hebrew-dates.ts",
    "storage:ensure-gallery-bucket": "npx dotenv-cli -e .env -- node scripts/ensure-person-galleries-bucket.cjs"
  },
  "dependencies": {
    "@hebcal/core": "^6.3.0",
    "@prisma/client": "^6.19.3",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.1",
    "@xyflow/react": "^12.10.2",
    "browser-image-compression": "^2.0.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "elkjs": "^0.11.1",
    "gray-matter": "^4.0.3",
    "next": "^15.3.0",
    "next-intl": "^4.9.1",
    "next-mdx-remote": "^6.0.0",
    "react": "^19.0.0",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.0.0",
    "resend": "^6.12.3",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.21",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9",
    "eslint-config-next": "^15.3.0",
    "postcss": "^8",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.1",
    "typescript": "^5"
  }
}
