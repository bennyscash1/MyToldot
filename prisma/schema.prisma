// ============================================================
// ShorTree — Prisma Schema
// Phase 1: Core relational architecture (SaaS-ready)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

/// Per-tree membership role (stored on `TreeMember`).
/// All gating happens at this level — there is no global RBAC.
/// EDITOR_PENDING is a viewer who has requested edit access but
/// hasn't been approved by an OWNER yet (treated as VIEWER for writes).
enum TreeMemberRole {
  VIEWER
  EDITOR_PENDING
  EDITOR
  OWNER
}

enum Gender {
  MALE
  FEMALE
  OTHER
  UNKNOWN
}

enum RelationshipType {
  SPOUSE // husband / wife / partner
  PARENT_CHILD // directional: person1 is the PARENT of person2
  SIBLING // person1 and person2 are siblings
  ENGAGED // betrothed, not yet married
  DIVORCED // formerly married
  ADOPTED_PARENT // person1 is the adoptive parent of person2
}

// ─────────────────────────────────────────────
// TREE  (one tree = one family unit / tenant)
// ─────────────────────────────────────────────

model Tree {
  id                         String   @id @default(cuid())
  slug                       String   @unique
  /// Public 5-digit join / URL code (unique).
  shortCode                  String   @unique @map("short_code")
  name                       String // e.g. "Asad Family"
  description                String?
  is_public                  Boolean  @default(false) // privacy gate
  strict_lineage_enforcement Boolean  @default(false) // when true: only blood/adoptive edges allowed; no informal links
  /// When false, lateral expansion is restricted (see `isPersonAllowed` in branching.ts).
  allow_branching              Boolean  @default(false) @map("allow_branching")
  // Long-form heritage description shown on the About page.
  about_text                 String?
  // Short list of family surnames highlighted on the About page.
  main_surnames              String[] @default([])
  /// Gallery images on the tree About page: [{ path, caption, order }], paths in profile-pictures bucket.
  about_images               Json?    @map("about_images")
  created_at                 DateTime @default(now())
  updated_at                 DateTime @updatedAt

  // Default focal person when the tree is opened (fallback: first-created person).
  // SetNull on delete so removing the person doesn't cascade into the tree.
  root_person_id String? @unique
  root_person    Person? @relation("TreeRootPerson", fields: [root_person_id], references: [id], onDelete: SetNull)

  // Relations
  members       TreeMember[]
  persons       Person[]
  relationships Relationship[]

  @@map("trees")
}

// ─────────────────────────────────────────────
// USER  (Supabase Auth user mirrored here)
// ─────────────────────────────────────────────

model User {
  id         String  @id // matches Supabase auth.users.id (UUID)
  email      String  @unique
  full_name  String?
  avatar_url String?
  // GOOGLE AUTH ADDED: Supabase user id for Google identity (when linked).
  googleId   String? @unique
  // GOOGLE AUTH ADDED: Auth source marker for manual/google/both flows.
  authProvider String @default("manual")
  /// UI locale persisted for signed-in users (`he` | `en`).
  preferred_language String @default("he")

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // A user can be a member of many trees with different roles.
  // All editing rights are enforced per-tree via TreeMember.role.
  tree_memberships TreeMember[]

  @@map("users")
}

// ─────────────────────────────────────────────
// TREE MEMBER  (join table: User × Tree + role)
// ─────────────────────────────────────────────

model TreeMember {
  id        String         @id @default(cuid())
  role      TreeMemberRole @default(VIEWER)
  joined_at DateTime       @default(now())

  // FK → Tree
  tree_id String
  tree    Tree   @relation(fields: [tree_id], references: [id], onDelete: Cascade)

  // FK → User
  user_id String
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  // Per-user "home" focal person in this tree (MyHeritage-style). Optional; when
  // null the viewer falls back to Tree.root_person_id.
  linked_person_id String?
  linked_person    Person? @relation("TreeMemberLinkedPerson", fields: [linked_person_id], references: [id], onDelete: SetNull)

  @@unique([tree_id, user_id]) // one membership per tree per user
  @@index([linked_person_id])
  @@map("tree_members")
}

// ─────────────────────────────────────────────
// PERSON  (a node in the family tree)
// ─────────────────────────────────────────────

model Person {
  id String @id @default(cuid())

  // Core identity
  first_name  String
  last_name   String?
  maiden_name String? // name before marriage
  gender      Gender    @default(UNKNOWN)
  birth_date  DateTime?
  death_date  DateTime?
  is_deceased Boolean   @default(false)
  birth_date_hebrew  String?
  birth_year_hebrew  String?
  death_date_hebrew  String?
  death_year_hebrew  String?
  birth_place String?
  bio         String? // free-text biography

  // Media (Supabase Storage path, not full URL)
  profile_image String? // e.g. "avatars/<person_id>.webp"

  // i18n display overrides (Hebrew names)
  first_name_he String?
  last_name_he  String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // ── Multi-tenancy FK ──
  tree_id String
  tree    Tree   @relation(fields: [tree_id], references: [id], onDelete: Cascade)

  // ── Relationship edges (both directions) ──
  relationships_as_person1 Relationship[] @relation("Person1Relationships")
  relationships_as_person2 Relationship[] @relation("Person2Relationships")

  // Back-relations for focal-person FKs (no application code ever reads these
  // directly; they exist so Prisma can resolve the opposing relation).
  root_of_tree        Tree?        @relation("TreeRootPerson")
  linked_tree_members TreeMember[] @relation("TreeMemberLinkedPerson")

  @@index([tree_id])
  @@map("persons")
}

// ─────────────────────────────────────────────
// RELATIONSHIP  (edge between two Person nodes)
// ─────────────────────────────────────────────

/// Encodes a directed or undirected edge between two persons.
/// Convention for PARENT_CHILD: person1 = parent, person2 = child.
/// All other types are treated as undirected (symmetric).
model Relationship {
  id                String           @id @default(cuid())
  relationship_type RelationshipType

  // Optional metadata
  start_date DateTime? // marriage date, adoption date, etc.
  end_date   DateTime? // divorce date, death, etc.
  notes      String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // ── Multi-tenancy FK ──
  tree_id String
  tree    Tree   @relation(fields: [tree_id], references: [id], onDelete: Cascade)

  // ── Person FKs ──
  person1_id String
  person1    Person @relation("Person1Relationships", fields: [person1_id], references: [id], onDelete: Cascade)

  person2_id String
  person2    Person @relation("Person2Relationships", fields: [person2_id], references: [id], onDelete: Cascade)

  // Prevent duplicate edges of the same type between the same two persons
  @@unique([tree_id, person1_id, person2_id, relationship_type])
  @@index([tree_id])
  @@index([person1_id])
  @@index([person2_id])
  @@index([tree_id, relationship_type])
  @@map("relationships")
}
